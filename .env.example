# --- AI enrichment (context engine + harmonization) ---------------------
# The context engine auto-detects providers: Anthropic first, then xAI.
# With no key set, builds are heuristic and fully offline.

# Anthropic (Claude) — used by scripts/context_engine (`build --ai auto|anthropic`)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ...or wire it through Claude Code OAuth instead of an API key:
# run `claude setup-token` and export the result (Bearer auth is used
# automatically when no API key is set; ANTHROPIC_AUTH_TOKEN also works)
# CLAUDE_CODE_OAUTH_TOKEN=your-claude-code-oauth-token
# Optional: override the enrichment model (default: claude-opus-4-8)
# CONTEXT_AI_MODEL=claude-opus-4-8

# xAI (Grok) — used by the context engine and scripts/harmonize
# Get your API key from: https://console.x.ai/
XAI_API_KEY=your-xai-api-key-here
# Alternative environment variable name (either works)
# GROK_API_KEY=your-xai-api-key-here

# Optional: customize Grok API settings
# GROK_MODEL=grok-4-1-fast-reasoning
# GROK_MAX_TOKENS=4096
# GROK_TEMPERATURE=0.3
# GROK_TIMEOUT=60

# --- Context engine hooks ------------------------------------------------
# Make a failing hooks.d/ hook abort the build (default: report and continue)
# CONTEXT_HOOKS_STRICT=1

# --- Wiki.js Configuration ------------------------------------------------
# Database Configuration
WIKI_DB_USER=wikijs
WIKI_DB_PASS=wikijsrocks
WIKI_DB_NAME=wiki

# Wiki.js Settings
WIKI_ADMIN_EMAIL=admin@example.com
WIKI_SITE_URL=http://localhost:3000
WIKI_PORT=3000
WIKI_UPGRADE_COMPANION=0

# Optional: pgAdmin Configuration (for database management)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
